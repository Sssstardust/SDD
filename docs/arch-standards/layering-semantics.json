{
  "layers": {
    "ui": {
      "suffixes": ["UI"]
    },
    "controller": {
      "suffixes": ["Controller"]
    },
    "service": {
      "suffixes": ["Service"]
    },
    "repository": {
      "suffixes": ["Repository"]
    },
    "state_machine": {
      "suffixes": ["StateMachine"]
    }
  },
  "direction_rules": [
    {
      "from": "ui",
      "allowed_to": ["controller"],
      "error": "UI 不应直接调用 {dst_name}"
    },
    {
      "from": "controller",
      "allowed_to": ["service", "state_machine"],
      "error": "Controller 不应直接调用 {dst_name}"
    },
    {
      "from": "repository",
      "allowed_to": [],
      "error": "Repository 不应作为主动调用方: {src_name} -> {dst_name}"
    },
    {
      "from": "service",
      "forbidden_to": ["ui"],
      "error": "Service 不应直接依赖 UI: {src_name} -> {dst_name}"
    },
    {
      "from": "state_machine",
      "forbidden_to": ["ui", "controller"],
      "error": "StateMachine 不应直接依赖上层: {src_name} -> {dst_name}"
    }
  ]
}
