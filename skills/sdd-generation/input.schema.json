{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skills/sdd-generation/input.schema.json",
  "title": "SDD Generation Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspace", "output"],
  "properties": {
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "output": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": ["string", "null"]
    },
    "resume": {
      "type": "boolean"
    },
    "force": {
      "type": "boolean"
    },
    "no_ai": {
      "type": "boolean"
    },
    "ai_only": {
      "type": "boolean"
    }
  }
}
