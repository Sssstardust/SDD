{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skills/requirement-analyzer/schema.json",
  "title": "Structured PRD",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "feature_name",
    "feature_type",
    "one_liner",
    "project_mode",
    "project_mode_source",
    "project_mode_confidence",
    "project_mode_evidence",
    "project_mode_confirmed_by",
    "capability_tags",
    "risk_tier",
    "requirements",
    "ambiguities",
    "entities",
    "apis",
    "business_rules",
    "dependencies",
    "logic_atoms",
    "metadata"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ready", "clarify"]
    },
    "feature_name": {
      "type": "string",
      "minLength": 1
    },
    "feature_type": {
      "type": "string",
      "minLength": 1
    },
    "one_liner": {
      "type": "string",
      "minLength": 1
    },
    "project_mode": {
      "type": "string",
      "enum": ["brownfield", "greenfield", "hybrid"]
    },
    "project_mode_source": {
      "type": "string",
      "enum": ["heuristic", "ai", "manual", "mixed"]
    },
    "project_mode_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "project_mode_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "project_mode_confirmed_by": {
      "type": "string",
      "minLength": 1
    },
    "capability_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "high"]
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "apis": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/api"
      }
    },
    "business_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "logic_atoms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/logic_atom"
      }
    },
    "clarify": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/clarify"
        }
      ]
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "logic_atom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["req_id", "logic"],
      "properties": {
        "req_id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3}$"
        },
        "logic": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/logic_step"
          }
        }
      }
    },
    "logic_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "method", "steps"],
      "properties": {
        "component": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["req_id", "priority", "title", "description"],
      "properties": {
        "req_id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3}$"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "evidence"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path", "summary", "evidence"],
      "properties": {
        "method": {
          "type": "string",
          "pattern": "^(GET|POST|PUT|PATCH|DELETE|CALL)$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clarify": {
      "type": "object",
      "additionalProperties": false,
      "required": ["missing_fields", "questions", "suggested_overrides"],
      "properties": {
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suggested_overrides": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_file", "generated_at", "generator", "ai_used", "notes"],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "generator": {
          "type": "string",
          "minLength": 1
        },
        "ai_used": {
          "type": "boolean"
        },
        "ai_model": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
