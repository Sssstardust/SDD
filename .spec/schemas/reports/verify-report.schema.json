{
  "type": "object",
  "required": [
    "feature_name",
    "design_version",
    "checked_at",
    "test_file",
    "result",
    "details"
  ],
  "properties": {
    "feature_name": { "type": "string" },
    "design_version": { "type": "string" },
    "checked_at": { "type": "string" },
    "test_file": { "type": "string" },
    "result": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
    "coverage_result": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
    "execution": {
      "type": "object",
      "required": ["status", "mode"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIPPED"] },
        "mode": { "type": "string" },
        "reason": { "type": "string" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "returncode": { "type": "number" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" }
      }
    },
    "uncovered_p0": { "type": "array", "items": { "type": "string" } },
    "uncovered_p1": { "type": "array", "items": { "type": "string" } },
    "details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["req_id", "priority", "test_method", "covered"],
        "properties": {
          "req_id": { "type": "string" },
          "priority": { "type": "string" },
          "test_method": { "type": "string" },
          "covered": { "type": "boolean" }
        }
      }
    }
  }
}
