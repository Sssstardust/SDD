# PolyQuery MCP 配置
# 复制此文件为 .env 并填写实际的数据库连接信息

# ==================== 多数据源配置 ====================
# 使用 *_CONFIGS 格式配置多个数据源，值为 JSON 格式
# 格式: {"数据源名称": "连接URL", "另一个数据源": "连接URL"}

# MySQL 多数据源配置示例
MYSQL_CONFIGS={"primary":"mysql://username:password@primary-host:3306/database","replica":"mysql://username:password@replica-host:3306/database","analytics":"mysql://username:password@analytics-host:3306/report_db"}

# PostgreSQL 多数据源配置示例
POSTGRES_CONFIGS={"main":"postgresql://username:password@host:5432/main_db","archive":"postgresql://username:password@host:5432/archive_db"}

# MongoDB 多数据源配置示例 (支持 mongodb:// 和 mongodb+srv://)
MONGODB_CONFIGS={"main":"mongodb://username:password@host:27017/main_db","analytics":"mongodb://username:password@host:27017/analytics_db"}

# Redis 多数据源配置示例
REDIS_CONFIGS={"cache":"redis://:password@host:6379/0","session":"redis://:password@host:6379/1","queue":"redis://:password@host:6379/2"}

# SQLite 多数据源配置示例 (值为文件路径)
SQLITE_CONFIGS={"main":"/path/to/main.db","archive":"/path/to/archive.db"}

# Oracle 多数据源配置示例
ORACLE_CONFIGS={"main":"oracle://username:password@host:1521/main_service","report":"oracle://username:password@host:1521/report_service"}

# ==================== 安全配置 ====================

# 只读模式 - 禁止 INSERT/UPDATE/DELETE 等写操作
READ_ONLY_MODE=true
TABLE_WHITELIST=users,orders,public.audit_logs
CONNECTION_ROLE=readonly-replica
ALLOW_PROD_PRIMARY=false

# 最大返回行数
MAX_ROWS=1000

# 查询超时（毫秒）
QUERY_TIMEOUT=30000

# 日志级别
LOG_LEVEL=INFO
