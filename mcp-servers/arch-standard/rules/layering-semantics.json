{
  "layers": {
    "ui": {
      "suffixes": ["UI"]
    },
    "controller": {
      "suffixes": ["Controller"]
    },
    "listener": {
      "suffixes": ["Listener"]
    },
    "service": {
      "suffixes": ["Service", "ServiceImpl"]
    },
    "repository": {
      "suffixes": ["Repository"]
    },
    "state_machine": {
      "suffixes": ["StateMachine"]
    }
  },
  "direction_rules": [
    {
      "from": "ui",
      "allowed_to": ["controller"],
      "error": "UI 涓嶅簲鐩存帴璋冪敤 {dst_name}"
    },
    {
      "from": "controller",
      "allowed_to": ["service", "state_machine"],
      "error": "Controller 涓嶅簲鐩存帴璋冪敤 {dst_name}"
    },
    {
      "from": "listener",
      "allowed_to": ["service"],
      "error": "Listener 涓嶅簲鐩存帴璋冪敤 {dst_name}"
    },
    {
      "from": "repository",
      "allowed_to": [],
      "error": "Repository 涓嶅簲浣滀负涓诲姩璋冪敤鏂? {src_name} -> {dst_name}"
    },
    {
      "from": "service",
      "forbidden_to": ["ui"],
      "error": "Service 涓嶅簲鐩存帴渚濊禆 UI: {src_name} -> {dst_name}"
    },
    {
      "from": "state_machine",
      "forbidden_to": ["ui", "controller"],
      "error": "StateMachine 涓嶅簲鐩存帴渚濊禆涓婂眰: {src_name} -> {dst_name}"
    }
  ]
}
