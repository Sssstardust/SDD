{
  "name": "arch-standard-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for exposing architecture standards and structured constraints for SDD workflows.",
  "type": "commonjs",
  "bin": {
    "arch-standard-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "author": "SDD Team",
  "files": [
    "dist/",
    "src/",
    "rules/",
    "tsconfig.json"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "cli:list": "node dist/server.js --tool list_rules",
    "pack:check": "npm pack --dry-run --cache ./.npm-pack-cache"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "arch-standard",
    "architecture-rules",
    "constraints",
    "sdd"
  ],
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED"
}
